@model ProgressViewModel

<div class="text-center">
    <h1 class="display-4">Progress</h1>
    <p class="text-primary">Track your progress.</p>
</div>

<div class="container mt-4">
    <h2>Progress Tracker</h2>
    
    <div class="card-2 mb-5">
        <div class="card-body">
            <form asp-action="Add" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Workout Type:</label>
                    <select asp-for="Workout.WorkoutTypeId" class="form-control"
                            asp-items="@(new SelectList(Model.WorkoutTypes, "Id", "Name"))">
                        <option value="">Select Type</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Date:</label>
                    <input asp-for="Workout.Date" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Duration (minutes):</label>
                    <input asp-for="Workout.Duration" type="number" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Notes:</label>
                    <textarea asp-for="Workout.Notes" class="form-control" rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Add Progress</button>
            </form>
        </div>
    </div>

    <h2>Your Progress History</h2>

    <div class="card-2">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>DATE</th>
                        <th>WORKOUT TYPE</th>
                        <th>DURATION</th>
                        <th>NOTES</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var workout in Model.History)
                    {
                        <tr>
                            <td>@workout.Date.ToShortDateString()</td>
                            <td>@workout.WorkoutType?.Name</td>
                            <td>@workout.Duration min</td>
                            <td>@workout.Notes</td>
                            <td>
                                <form class="delete-form" asp-action="Delete" asp-controller="Progress" method="post">
                                    <input type="hidden" name="id" value="@workout.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.History.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No workouts recorded yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.delete-form').forEach(form => {
        form.addEventListener('submit', function (e) {
            if (!confirm('Are you sure you want to delete this workout?')) {
                e.preventDefault();
            }
        });
    });
</script>
