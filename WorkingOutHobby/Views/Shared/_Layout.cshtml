<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkingOutHobby</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkingOutHobby.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-dark shadow-sm mb-4" data-bs-theme="dark">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">WORKING OUT HUB</a>
                <button class="navbar-toggler border-0 p-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="#mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <img src="~/images/nav.png" alt="Toggle navigation" class="nav-toggle-icon" />
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AboutWorkingOut">About Hobby</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AboutTheCreators">About Creators</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Workout" asp-action="Routines">Routines</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Workout" asp-action="Equipment">Equipment</a>
                        </li>
                        <li class="nav-item auth-only" style="display:none;">
                            <a class="nav-link text-dark fw-bold" asp-controller="Progress" asp-action="Index">Progress</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item guest-only">
                            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item auth-only" style="display:none;">
                            <button class="btn btn-link nav-link text-danger" onclick="logoutUser()">Logout</button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WorkingOutHobby - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const isLoggedIn = localStorage.getItem("isLoggedIn") === "true";
        
        if (isLoggedIn) {
            // Show Progress and Logout
            document.querySelectorAll('.auth-only').forEach(el => el.style.setProperty('display', 'block', 'important'));
            // Hide Login
            document.querySelectorAll('.guest-only').forEach(el => el.style.setProperty('display', 'none', 'important'));
        }
    });

    async function logoutUser() {
        localStorage.removeItem("isLoggedIn");
        localStorage.removeItem("jwt");
        localStorage.removeItem("refreshToken");

        await fetch('/api/auth/logout', { method: 'POST' });

        window.location.href = '/';
    }
</script>
